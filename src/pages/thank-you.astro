---
import Base from '../layouts/Base.astro';
---
<Base
  title="Thank you — Adventure Access"
  description="Thanks for reaching out. One of our travel specialists will be in touch within 24 hours."
  noindex={true}
>
  <article class="pt-40 md:pt-48 pb-32 md:pb-40">
    <div class="max-w-2xl mx-auto px-6 md:px-14 text-center">
      <div class="eyebrow mb-6">— Inquiry received</div>
      <h1 class="display text-5xl md:text-6xl mb-8">Thank you.</h1>
      <p class="text-lg md:text-xl leading-relaxed text-ink-soft mb-12">
        Your message is on its way to our team. One of our travel specialists will
        reply within 24 hours — usually sooner — to start shaping your journey.
      </p>
      <p class="text-ink-soft mb-10">
        If it's urgent, write directly to
        <a class="text-saffron border-b border-saffron/40 hover:border-saffron transition-colors" href="mailto:info@adventure-access.com">info@adventure-access.com</a>.
      </p>
      <a href="/" class="btn !bg-saffron hover:!bg-saffron-dark inline-block">Back to home</a>
    </div>
  </article>
</Base>
