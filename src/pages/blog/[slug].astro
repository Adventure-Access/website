---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Sort all posts newest-first to find prev/next
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const idx = allPosts.findIndex((p) => p.slug === entry.slug);
const newer = idx > 0 ? allPosts[idx - 1] : null;
const older = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

// Trim excerpt to 155 chars for meta description
const rawExcerpt = entry.data.excerpt ?? '';
const metaDescription = rawExcerpt.length > 155
  ? rawExcerpt.slice(0, 155).replace(/\s+\S*$/, '') + '…'
  : rawExcerpt;

// BreadcrumbList schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: 'Journal', item: new URL('/blog/', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: entry.data.title, item: new URL(`/blog/${entry.slug}/`, Astro.site).toString() },
  ],
};

// Article schema
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  datePublished: entry.data.date.toISOString(),
  dateModified: entry.data.date.toISOString(),
  description: metaDescription,
  image: entry.data.featured_image ? new URL(entry.data.featured_image, Astro.site).toString() : undefined,
  url: new URL(`/blog/${entry.slug}/`, Astro.site).toString(),
  author: { '@type': 'Organization', name: 'Adventure Access' },
  publisher: {
    '@type': 'Organization',
    name: 'Adventure Access',
    logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).toString() },
  },
  mainEntityOfPage: new URL(`/blog/${entry.slug}/`, Astro.site).toString(),
};

// Destination CTA data — used when post has a destination field
const destinationMeta: Record<string, { name: string; country: string; href: string }> = {
  ladakh:  { name: 'Ladakh & Zanskar', country: 'India',  href: '/destinations/ladakh'  },
  nepal:   { name: 'Nepal',            country: 'Nepal',  href: '/destinations/nepal'   },
  bhutan:  { name: 'Bhutan',           country: 'Bhutan', href: '/destinations/bhutan'  },
  yunnan:  { name: 'Yunnan & Lijiang', country: 'China',  href: '/destinations/yunnan'  },
};
const destCta = entry.data.destination ? destinationMeta[entry.data.destination] : null;
---
<Base
  title={`${entry.data.title} — AA Journal`}
  description={metaDescription || `Read ${entry.data.title} on the Adventure Access journal.`}
  ogImage={entry.data.featured_image || undefined}
  schema={[articleSchema, breadcrumbSchema]}
>
  {entry.data.featured_image && (
    <section class="relative h-[60vh] md:h-[78vh] flex items-end overflow-hidden bg-ink">
      <img src={entry.data.featured_image} alt={entry.data.title} class="absolute inset-0 w-full h-full object-cover kenburns" />
      <div class="absolute inset-0 bg-gradient-to-b from-ink/30 via-ink/10 to-ink/85"></div>
      <div class="relative max-w-4xl mx-auto w-full px-6 md:px-14 pb-14 md:pb-24 text-cream">
        <div class="eyebrow-cream mb-5 fade-up text-shadow-hero">— The Journal · {formatDate(entry.data.date)}</div>
        <h1 class="display text-4xl md:text-6xl leading-tight max-w-3xl fade-up-delay-1 text-shadow-hero">{entry.data.title}</h1>
      </div>
    </section>
  )}

  {!entry.data.featured_image && (
    <section class="pt-32 md:pt-40 pb-8">
      <div class="max-w-3xl mx-auto px-6 md:px-14">
        <div class="eyebrow mb-5">— The Journal · {formatDate(entry.data.date)}</div>
        <h1 class="display text-5xl md:text-6xl">{entry.data.title}</h1>
      </div>
    </section>
  )}

  <article class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-6 md:px-14">
      <div class="prose-post text-lg leading-relaxed text-ink-soft">
        <Content />
      </div>
    </div>
  </article>

  {/* Photo Gallery — rendered when post has gallery images */}
  {entry.data.gallery && entry.data.gallery.length > 0 && (
    <section class="py-16 md:py-20 border-t border-ink/10">
      <div class="max-w-5xl mx-auto px-6 md:px-14">
        <div class="eyebrow mb-8">— Photos</div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
          {entry.data.gallery.map((src: string, i: number) => (
            <div class="aspect-[4/3] overflow-hidden bg-paper">
              <img
                src={src}
                alt={`${entry.data.title} — photo ${i + 1}`}
                loading="lazy"
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Destination CTA — only rendered when post has a destination field */}
  {destCta && (
    <section class="bg-paper border-t border-ink/10 py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-6 md:px-14 flex flex-col md:flex-row md:items-center gap-8 md:gap-16">
        <div class="flex-1">
          <div class="eyebrow mb-3">— Explore the destination</div>
          <h2 class="display text-3xl md:text-4xl mb-3">{destCta.name}</h2>
          <p class="text-ink-soft leading-relaxed">
            Read more about traveling in {destCta.country} with Adventure Access — culture, adventure, and how to plan your trip.
          </p>
        </div>
        <a href={destCta.href} class="btn shrink-0">Explore {destCta.name} →</a>
      </div>
    </section>
  )}

  <nav class="border-t border-ink/15 py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-6 md:px-14 grid md:grid-cols-2 gap-10">
      {newer ? (
        <a href={`/blog/${newer.slug}`} class="group block">
          <div class="eyebrow mb-2">← Newer</div>
          <div class="font-display text-xl md:text-2xl group-hover:text-saffron-dark transition-colors">{newer.data.title}</div>
        </a>
      ) : <div></div>}
      {older ? (
        <a href={`/blog/${older.slug}`} class="group block md:text-right">
          <div class="eyebrow mb-2">Older →</div>
          <div class="font-display text-xl md:text-2xl group-hover:text-saffron-dark transition-colors">{older.data.title}</div>
        </a>
      ) : <div></div>}
    </div>
  </nav>

  <section class="bg-paper py-16 text-center">
    <a href="/blog" class="btn-ghost">← Back to the Journal</a>
  </section>
</Base>

<style is:global>
  .prose-post p { margin-bottom: 1.4rem; }
  .prose-post p.lead {
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    line-height: 1.45;
    color: #2b3540;
    margin-bottom: 2rem;
    font-weight: 400;
  }
  @media (min-width: 768px) {
    .prose-post p.lead { font-size: 1.75rem; }
  }
  .prose-post h2, .prose-post h3, .prose-post h4 {
    font-family: 'Fraunces', serif; color: #2b3540;
    margin-top: 3rem; margin-bottom: 1.25rem;
    line-height: 1.1;
  }
  .prose-post h2 { font-size: 2.25rem; }
  .prose-post h3 { font-size: 1.6rem; }
  .prose-post h4 { font-size: 1.3rem; }
  .prose-post strong { color: #2b3540; font-weight: 600; }
  .prose-post em { font-style: italic; }
  .prose-post a { color: #d97a2c; text-decoration: underline; text-underline-offset: 3px; }
  .prose-post a:hover { color: #b85e1a; }
  .prose-post ul, .prose-post ol { padding-left: 1.5rem; margin-bottom: 1.4rem; }
  .prose-post li { margin-bottom: 0.5rem; }
  .prose-post blockquote {
    border-left: 3px solid #d97a2c;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 1.25rem;
    color: #2b3540;
  }
  .prose-post img {
    width: 100%;
    height: auto;
    margin: 2rem 0;
    display: block;
  }
  .prose-post .aligncenter { margin-left: auto; margin-right: auto; }
  .prose-post .alignleft  { float: left;  margin-right: 1.5rem; margin-bottom: 1rem; }
  .prose-post .alignright { float: right; margin-left: 1.5rem;  margin-bottom: 1rem; }
  .prose-post figure { margin: 3rem -2rem; }
  @media (min-width: 1024px) {
    .prose-post figure { margin: 4rem -8rem; }
  }
  .prose-post figure img { margin: 0; aspect-ratio: 16 / 10; object-fit: cover; }
  .prose-post figcaption {
    font-size: 0.875rem;
    color: #5a6470;
    text-align: center;
    margin-top: 0.75rem;
    font-style: italic;
    letter-spacing: 0.02em;
  }
  .prose-post table { width: 100%; margin: 1.5rem 0; border-collapse: collapse; }
  .prose-post th, .prose-post td { border-bottom: 1px solid #e5dfd0; padding: 0.75rem 0.5rem; text-align: left; }
  .prose-post iframe { width: 100%; aspect-ratio: 16/9; margin: 2rem 0; border: 0; }
</style>
