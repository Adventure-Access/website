---
export interface Props {
  slug: string;
  title: string;
  excerpt?: string;
  category?: string;
  image?: string;
}
const { slug, title, excerpt, category, image } = Astro.props;
const fallbackImage = '/images/2024/05/IMG_2802-1920x900.jpg';
const imgSrc = image || fallbackImage;
---
<a href={`/tours/${slug}`} class="group block bg-paper/40 hover:bg-paper transition-colors">
  <div class="aspect-[4/3] overflow-hidden bg-paper">
    <img src={imgSrc} alt={title} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
  </div>
  <div class="p-7">
    {category && <div class="eyebrow mb-3">— {category}</div>}
    <h3 class="font-display font-medium text-2xl leading-tight tracking-tight mb-3 group-hover:text-saffron-dark transition-colors">{title}</h3>
    {excerpt && <p class="text-ink-soft text-sm leading-relaxed line-clamp-3">{excerpt}</p>}
    <div class="mt-4 text-xs uppercase tracking-[0.15em] font-medium text-saffron">View Itinerary →</div>
  </div>
</a>
