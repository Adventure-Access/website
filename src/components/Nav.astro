---
export interface Props { transparent?: boolean; }
const { transparent = false } = Astro.props;
const navClass = transparent
  ? 'absolute inset-x-0 top-0 z-50 text-cream'
  : 'sticky top-0 z-50 bg-cream/95 backdrop-blur border-b border-ink/10 text-ink';

const links = [
  { href: '/destinations',            label: 'Destinations' },
  { href: '/tours',                   label: 'Trips' },
  { href: '/transformational-travel', label: 'Transformation' },
  { href: '/about',                   label: 'About' },
  { href: '/blog',                    label: 'Journal' },
  { href: 'https://adventureprovisionco.com/', label: 'Gear', external: true },
];
---
<header class={navClass}>
  <div class="max-w-8xl mx-auto px-6 md:px-14 py-6 flex items-center justify-between">
    <a href="/" class="font-display text-2xl font-semibold tracking-tight flex items-center gap-1">
      Adventure<span class="text-saffron">·</span>Access
    </a>

    <nav class="hidden lg:flex items-center gap-9 text-sm font-medium tracking-wide">
      {links.map((l) => (
        <a
          href={l.href}
          target={l.external ? '_blank' : undefined}
          rel={l.external ? 'noopener' : undefined}
          class="hover:text-saffron transition-colors"
        >
          {l.label}
        </a>
      ))}
      <a href="/#contact" class={transparent
        ? "bg-cream text-ink px-5 py-2.5 text-xs uppercase tracking-[0.1em] font-semibold hover:bg-saffron hover:text-cream transition-colors"
        : "btn"}>Plan a Trip</a>
    </nav>

    <button
      id="nav-toggle"
      type="button"
      class="lg:hidden flex items-center gap-2 text-sm uppercase tracking-[0.1em] font-semibold border border-current px-3 py-1.5"
      aria-label="Open menu"
      aria-controls="nav-drawer"
      aria-expanded="false"
    >
      <span class="nav-toggle-label">Menu</span>
    </button>
  </div>
</header>

<!-- Mobile drawer (rendered outside the header so it can cover the whole viewport) -->
<div id="nav-drawer" class="nav-drawer lg:hidden" aria-hidden="true">
  <button
    type="button"
    class="nav-drawer__backdrop absolute inset-0 bg-ink/70 backdrop-blur-sm"
    aria-label="Close menu"
    tabindex="-1"
  ></button>

  <div class="nav-drawer__panel relative bg-cream text-ink shadow-2xl">
    <div class="flex items-center justify-between px-6 py-6 border-b border-ink/10">
      <a href="/" class="font-display text-2xl font-semibold tracking-tight flex items-center gap-1">
        Adventure<span class="text-saffron">·</span>Access
      </a>
      <button
        type="button"
        class="nav-drawer__close text-sm uppercase tracking-[0.1em] font-semibold border border-ink px-3 py-1.5"
        aria-label="Close menu"
      >
        Close
      </button>
    </div>
    <nav class="px-6 py-8 flex flex-col gap-1 text-2xl font-display">
      {links.map((l) => (
        <a
          href={l.href}
          target={l.external ? '_blank' : undefined}
          rel={l.external ? 'noopener' : undefined}
          class="nav-drawer__item py-3 border-b border-ink/10 hover:text-saffron transition-colors"
        >
          {l.label}
        </a>
      ))}
      <a href="/#contact" class="nav-drawer__item btn mt-6 w-fit">Plan a Trip</a>
    </nav>
  </div>
</div>

<script is:inline>
  (function () {
    const toggle = document.getElementById('nav-toggle');
    const drawer = document.getElementById('nav-drawer');
    if (!toggle || !drawer) return;

    const backdrop = drawer.querySelector('.nav-drawer__backdrop');
    const closeBtn = drawer.querySelector('.nav-drawer__close');
    const links    = drawer.querySelectorAll('a');
    const label    = toggle.querySelector('.nav-toggle-label');

    function open() {
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
      if (label) label.textContent = 'Close';
      document.body.style.overflow = 'hidden';
    }
    function close() {
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
      if (label) label.textContent = 'Menu';
      document.body.style.overflow = '';
    }
    function toggleDrawer() {
      if (drawer.classList.contains('is-open')) close();
      else open();
    }

    toggle.addEventListener('click', toggleDrawer);
    backdrop?.addEventListener('click', close);
    closeBtn?.addEventListener('click', close);
    links.forEach((a) => a.addEventListener('click', close));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.classList.contains('is-open')) close();
    });
  })();
</script>
