---
export interface Props { transparent?: boolean; }
const { transparent = false } = Astro.props;
const navClass = transparent
  ? 'absolute inset-x-0 top-0 z-50 text-cream'
  : 'sticky top-0 z-50 bg-cream/95 backdrop-blur border-b border-ink/10 text-ink';
---
<header class={navClass}>
  <div class="max-w-8xl mx-auto px-6 md:px-14 py-6 flex items-center justify-between">
    <a href="/" class="font-display text-2xl font-semibold tracking-tight flex items-center gap-1">
      Adventure<span class="text-saffron">·</span>Access
    </a>

    <nav class="hidden lg:flex items-center gap-9 text-sm font-medium tracking-wide">
      <a href="/transformational-travel" class="hover:text-saffron transition-colors">Destinations</a>
      <a href="/tours" class="hover:text-saffron transition-colors">Trips</a>
      <a href="/about" class="hover:text-saffron transition-colors">About</a>
      <a href="/blog" class="hover:text-saffron transition-colors">Journal</a>
      <a href="https://adventureprovisionco.com/" target="_blank" rel="noopener" class="hover:text-saffron transition-colors">Gear</a>
      <a href="/#contact" class={transparent
        ? "bg-cream text-ink px-5 py-2.5 text-xs uppercase tracking-[0.1em] font-semibold hover:bg-saffron hover:text-cream transition-colors"
        : "btn"}>Plan a Trip</a>
    </nav>

    <button
      class="lg:hidden text-sm uppercase tracking-[0.1em] font-semibold border border-current px-3 py-1.5"
      aria-label="Toggle menu"
      onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
    >
      Menu
    </button>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden border-t border-current/10 bg-cream text-ink">
    <nav class="px-6 py-6 flex flex-col gap-5 text-sm font-medium">
      <a href="/transformational-travel">Destinations</a>
      <a href="/tours">Trips</a>
      <a href="/about">About</a>
      <a href="/blog">Journal</a>
      <a href="https://adventureprovisionco.com/" target="_blank" rel="noopener">Gear</a>
      <a href="/#contact" class="btn w-fit">Plan a Trip</a>
    </nav>
  </div>
</header>
