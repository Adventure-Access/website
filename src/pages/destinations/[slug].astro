---
import Base from '../../layouts/Base.astro';
import destinations from '../../data/destinations.json';

export async function getStaticPaths() {
  const items = (await import('../../data/destinations.json')).default;
  return items.map((d: any) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const dest = destinations.find((d: any) => d.slug === slug);
if (!dest) throw new Error(`Destination not found: ${slug}`);

// Place JSON-LD
const placeSchema = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  name: dest.name,
  description: dest.blurb,
  image: new URL(dest.hero, Astro.site).toString(),
  url: new URL(`/destinations/${dest.slug}/`, Astro.site).toString(),
  containedInPlace: { '@type': 'Country', name: dest.country },
};

// BreadcrumbList JSON-LD
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: 'Destinations', item: new URL('/destinations/', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: dest.name, item: new URL(`/destinations/${dest.slug}/`, Astro.site).toString() },
  ],
};
---
<Base
  hideNavBg={true}
  title={`${dest.name} — Adventure Access`}
  description={(dest as any).metaDescription ?? dest.blurb}
  ogImage={dest.hero}
  schema={[placeSchema, breadcrumbSchema]}
>
  <!-- HERO -->
  <section class="relative min-h-[78vh] flex items-end">
    <img src={dest.hero} alt={dest.name} class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-b from-ink/20 via-transparent to-ink/75"></div>
    <div class="relative max-w-8xl mx-auto w-full px-6 md:px-14 pb-20 md:pb-24 text-cream">
      <div class="eyebrow mb-5">— {dest.country}</div>
      <h1 class="display text-6xl md:text-8xl mb-5">{dest.name}</h1>
      <p class="font-display italic text-2xl md:text-3xl text-cream/90 max-w-xl">{dest.tagline}</p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6 md:px-14">
      <p class="font-display text-3xl md:text-4xl leading-snug text-ink">{dest.intro}</p>
    </div>
  </section>

  <!-- SECTIONS (editorial) -->
  <section class="pb-24 md:pb-32">
    <div class="max-w-4xl mx-auto px-6 md:px-14 space-y-20">
      {dest.sections.map((s: any) => (
        <article>
          <div class="eyebrow mb-4">— Chapter</div>
          <h2 class="display text-4xl md:text-5xl mb-6">{s.title}</h2>
          <div class="text-lg leading-relaxed text-ink-soft space-y-5">
            {s.body.split('\n\n').map((p: string) => <p>{p}</p>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- TRIPS IN THIS REGION — Youli embed filtered by this destination's tag -->
  <section class="bg-paper py-24 md:py-32">
    <div class="max-w-8xl mx-auto px-6 md:px-14">
      <div class="flex flex-wrap justify-between items-end gap-6 mb-12">
        <div>
          <div class="eyebrow mb-4">— Bookable Trips</div>
          <h2 class="display text-4xl md:text-5xl">Journeys in <em class="not-italic font-light text-saffron font-display italic">{dest.name}</em>.</h2>
        </div>
        <a href="/tours" class="btn-ghost">View all trips →</a>
      </div>
      <div
        class="youli-embed youli-tagged"
        data-youli-tag={(dest as any).youliTag}
        data-youli-empty-note={`No scheduled departures in ${dest.name} right now — but every trip we run can be built custom.`}
      ></div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var mount = document.querySelector('.youli-tagged');
      if (!mount) return;
      var tag = mount.dataset.youliTag;
      var s = document.createElement('script');
      s.src = 'https://youli.io/embeds/script/trips/adventure-access/?view=card&style=detailed&tags=' + encodeURIComponent(tag);
      s.onload = function () {
        // If Youli rendered nothing for this tag, show a friendly note instead of a blank box.
        setTimeout(function () {
          if (!mount.querySelector('.trip-card-wrapper') && mount.children.length <= 1) {
            var p = document.createElement('p');
            p.className = 'text-ink-soft text-lg';
            p.textContent = mount.dataset.youliEmptyNote || 'No scheduled departures right now.';
            mount.appendChild(p);
          }
        }, 1500);
      };
      mount.appendChild(s);
    })();
  </script>

  <!-- GALLERY -->
  {dest.gallery && dest.gallery.length > 0 && (
    <section class="py-24 md:py-32">
      <div class="max-w-8xl mx-auto px-6 md:px-14">
        <div class="eyebrow mb-3">— Field Photos</div>
        <h2 class="display text-4xl md:text-5xl mb-12">From the field.</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-5">
          {dest.gallery.map((src: string, i: number) => (
            <div class={`overflow-hidden bg-paper ${i % 5 === 0 ? 'md:col-span-2 md:row-span-2 aspect-square' : 'aspect-[4/3]'}`}>
              <img src={src} alt={`${dest.name} — field photo ${i + 1}`} loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-ink text-cream py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6 md:px-14 text-center">
      <div class="eyebrow !text-saffron mb-6">— Ready?</div>
      <h2 class="display text-5xl md:text-6xl mb-8">Begin a journey<br>in <em class="not-italic font-light text-saffron font-display italic">{dest.country}</em>.</h2>
      <p class="text-lg text-cream/80 max-w-xl mx-auto mb-10">
        Tell us what experiences speak to you, and one of our travel specialists will design a journey shaped specifically for your group.
      </p>
      <a href="/plan" class="btn !bg-saffron hover:!bg-saffron-dark">Plan a Journey</a>
    </div>
  </section>
</Base>
