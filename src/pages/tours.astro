---
import Base from '../layouts/Base.astro';
---
<Base
  title="Trips — Adventure Access"
  description="Bookable adventures across the Himalayas and the Tibetan Plateau. Trekking, mountain biking, cultural immersion, and overland journeys in Bhutan, India, Nepal, and Yunnan."
>
  <!-- HERO ON PHOTO -->
  <section class="relative h-[55vh] md:h-[65vh] overflow-hidden bg-ink">
    <img
      src="/images/2025/11/MTB-Exploration-Photo-3-scaled.jpeg"
      alt="Mountain biker on a high-altitude trail"
      class="absolute inset-0 w-full h-full object-cover kenburns"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-ink/30 via-ink/10 to-ink/80"></div>
    <div class="relative z-10 h-full max-w-8xl mx-auto px-6 md:px-14 flex flex-col justify-end pb-14 md:pb-20 text-cream">
      <div class="max-w-3xl">
        <div class="eyebrow-cream mb-6 fade-up text-shadow-hero">— Trips · Bookable Now</div>
        <h1 class="display text-5xl md:text-8xl mb-6 fade-up-delay-1 text-shadow-hero">
          Choose your <em class="not-italic font-light text-saffron font-display italic">journey</em>.
        </h1>
        <p class="font-display text-lg md:text-2xl text-cream/90 italic leading-relaxed max-w-2xl fade-up-delay-2 text-shadow-hero">
          Every trip is led by our local guides and shaped around small groups. Pick one to see the full itinerary, dates, and pricing — or use it as a starting point for something custom.
        </p>
      </div>
    </div>
  </section>

  <!-- YOULI EMBED -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="max-w-8xl mx-auto px-6 md:px-14 reveal">
      <div id="youli-embed-mount" class="youli-embed">
        <script
          is:inline
          src="https://youli.io/embeds/script/trips/adventure-access/?view=card&style=detailed"
        ></script>
      </div>
      <noscript>
        <p class="text-center text-ink-soft py-12">
          Our trip list is hosted on Youli. Please
          <a href="https://youli.io/trips/adventure-access/" class="text-saffron underline" target="_blank" rel="noopener">view our trips directly</a>
          if you have JavaScript disabled.
        </p>
      </noscript>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-ink text-cream py-28 md:py-36 relative overflow-hidden">
    <div class="absolute top-1/2 left-0 -translate-y-1/2 -translate-x-1/4 select-none pointer-events-none opacity-[0.04] overflow-hidden hidden md:block" aria-hidden="true">
      <span class="font-display font-light text-[22vw] uppercase whitespace-nowrap">Custom</span>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-14 text-center reveal">
      <div class="eyebrow !text-saffron mb-6">— Don't see exactly what you want?</div>
      <h2 class="display text-5xl md:text-7xl mb-8">Let's design <em class="not-italic font-light text-saffron font-display italic">your own</em>.</h2>
      <p class="text-lg text-cream/80 max-w-xl mx-auto mb-10">
        Tell us where your curiosity lives and one of our travel specialists will shape an itinerary specifically for your group.
      </p>
      <a href="/#contact" class="btn !bg-saffron hover:!bg-saffron-dark">Start a Conversation</a>
    </div>
  </section>
</Base>

<style is:global>
  /* Make the Youli widget look at home — paint over whatever default styling it ships with where possible. */
  .youli-embed {
    min-height: 400px;
  }
  .youli-embed iframe,
  .youli-embed > div {
    max-width: 100%;
  }
</style>
