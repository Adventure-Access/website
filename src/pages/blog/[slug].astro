---
import Base from '../../layouts/Base.astro';
import posts from '../../data/blog-posts.json';

export async function getStaticPaths() {
  const data = (await import('../../data/blog-posts.json')).default as Array<any>;
  return data.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const all = posts as Array<any>;
const idx = all.findIndex(p => p.slug === slug);
if (idx === -1) throw new Error(`Post not found: ${slug}`);
const post = all[idx];
const newer = idx > 0 ? all[idx - 1] : null;
const older = idx < all.length - 1 ? all[idx + 1] : null;

function formatDate(iso: string) {
  if (!iso) return '';
  const d = new Date(iso.replace(' ', 'T') + 'Z');
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

// Fallback excerpt from body text when WP didn't give us one
function fallbackExcerpt(html: string, max = 200): string {
  if (!html) return '';
  const stripped = html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  if (stripped.length <= max) return stripped;
  return stripped.slice(0, max).replace(/\s+\S*$/, '') + '…';
}
const effectiveExcerpt = post.excerpt || fallbackExcerpt(post.body_html);

// Add loading="lazy" to body images that don't already have it
const bodyHtml = (post.body_html || '').replace(
  /<img(?![^>]*loading=)([^>]*)>/g,
  '<img loading="lazy"$1>'
);

// Article JSON-LD
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  datePublished: post.date,
  dateModified: post.date,
  description: effectiveExcerpt,
  image: post.featured_image ? new URL(post.featured_image, Astro.site).toString() : undefined,
  url: new URL(`/blog/${post.slug}/`, Astro.site).toString(),
  author: { '@type': 'Organization', name: 'Adventure Access' },
  publisher: {
    '@type': 'Organization',
    name: 'Adventure Access',
    logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).toString() },
  },
  mainEntityOfPage: new URL(`/blog/${post.slug}/`, Astro.site).toString(),
};
---
<Base
  title={`${post.title} — AA Journal`}
  description={effectiveExcerpt || `Read ${post.title} on the Adventure Access journal.`}
  ogImage={post.featured_image || undefined}
  schema={articleSchema}
>
  {post.featured_image && (
    <section class="relative h-[60vh] md:h-[78vh] flex items-end overflow-hidden bg-ink">
      <img src={post.featured_image} alt={post.title} class="absolute inset-0 w-full h-full object-cover kenburns" />
      <div class="absolute inset-0 bg-gradient-to-b from-ink/30 via-ink/10 to-ink/85"></div>
      <div class="relative max-w-4xl mx-auto w-full px-6 md:px-14 pb-14 md:pb-24 text-cream">
        <div class="eyebrow-cream mb-5 fade-up text-shadow-hero">— The Journal · {formatDate(post.date)}</div>
        <h1 class="display text-4xl md:text-6xl leading-tight max-w-3xl fade-up-delay-1 text-shadow-hero">{post.title}</h1>
      </div>
    </section>
  )}

  {!post.featured_image && (
    <section class="pt-32 md:pt-40 pb-8">
      <div class="max-w-3xl mx-auto px-6 md:px-14">
        <div class="eyebrow mb-5">— The Journal · {formatDate(post.date)}</div>
        <h1 class="display text-5xl md:text-6xl">{post.title}</h1>
      </div>
    </section>
  )}

  <article class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-6 md:px-14">
      <div class="prose-post text-lg leading-relaxed text-ink-soft" set:html={bodyHtml}></div>
    </div>
  </article>

  <nav class="border-t border-ink/15 py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-6 md:px-14 grid md:grid-cols-2 gap-10">
      {newer ? (
        <a href={`/blog/${newer.slug}`} class="group block">
          <div class="eyebrow mb-2">← Newer</div>
          <div class="font-display text-xl md:text-2xl group-hover:text-saffron-dark transition-colors">{newer.title}</div>
        </a>
      ) : <div></div>}
      {older ? (
        <a href={`/blog/${older.slug}`} class="group block md:text-right">
          <div class="eyebrow mb-2">Older →</div>
          <div class="font-display text-xl md:text-2xl group-hover:text-saffron-dark transition-colors">{older.title}</div>
        </a>
      ) : <div></div>}
    </div>
  </nav>

  <section class="bg-paper py-16 text-center">
    <a href="/blog" class="btn-ghost">← Back to the Journal</a>
  </section>
</Base>

<style is:global>
  .prose-post p { margin-bottom: 1.4rem; }
  .prose-post p.lead {
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    line-height: 1.45;
    color: #2b3540;
    margin-bottom: 2rem;
    font-weight: 400;
  }
  @media (min-width: 768px) {
    .prose-post p.lead { font-size: 1.75rem; }
  }
  .prose-post h2, .prose-post h3, .prose-post h4 {
    font-family: 'Fraunces', serif; color: #2b3540;
    margin-top: 3rem; margin-bottom: 1.25rem;
    line-height: 1.1;
  }
  .prose-post h2 { font-size: 2.25rem; }
  .prose-post h3 { font-size: 1.6rem; }
  .prose-post h4 { font-size: 1.3rem; }
  .prose-post strong { color: #2b3540; font-weight: 600; }
  .prose-post em { font-style: italic; }
  .prose-post a { color: #d97a2c; text-decoration: underline; text-underline-offset: 3px; }
  .prose-post a:hover { color: #b85e1a; }
  .prose-post ul, .prose-post ol { padding-left: 1.5rem; margin-bottom: 1.4rem; }
  .prose-post li { margin-bottom: 0.5rem; }
  .prose-post blockquote {
    border-left: 3px solid #d97a2c;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 1.25rem;
    color: #2b3540;
  }
  .prose-post img {
    width: 100%;
    height: auto;
    margin: 2rem 0;
    display: block;
  }
  .prose-post .aligncenter { margin-left: auto; margin-right: auto; }
  .prose-post .alignleft  { float: left;  margin-right: 1.5rem; margin-bottom: 1rem; }
  .prose-post .alignright { float: right; margin-left: 1.5rem;  margin-bottom: 1rem; }
  .prose-post figure {
    margin: 3rem -2rem;
  }
  @media (min-width: 1024px) {
    .prose-post figure {
      /* Let figures break out of the narrow text column for impact */
      margin: 4rem -8rem;
    }
  }
  .prose-post figure img { margin: 0; aspect-ratio: 16 / 10; object-fit: cover; }
  .prose-post figcaption {
    font-size: 0.875rem;
    color: #5a6470;
    text-align: center;
    margin-top: 0.75rem;
    font-style: italic;
    letter-spacing: 0.02em;
  }
  .prose-post table { width: 100%; margin: 1.5rem 0; border-collapse: collapse; }
  .prose-post th, .prose-post td { border-bottom: 1px solid #e5dfd0; padding: 0.75rem 0.5rem; text-align: left; }
  .prose-post iframe { width: 100%; aspect-ratio: 16/9; margin: 2rem 0; border: 0; }
</style>
