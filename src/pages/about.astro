---
import Base from '../layouts/Base.astro';

const team = [
  {
    name: 'Brian',
    region: 'Bhutan, China, India, Nepal',
    image: '/images/2023/06/Brian-1024x720.jpg',
    bio: "I consider myself a guide to many — and that started long before I worked the trails. My wife and I take our five kids on adventures around the world. Through Adventure Access I invest time and energy in local adventure entrepreneurs throughout Bhutan, China, India and Nepal. My favourite ways to explore the region are mountain biking, trekking, mountaineering, rock climbing, and paddling.",
  },
  {
    name: 'Trevor',
    region: 'India',
    image: '/images/2023/06/Trevor-1024x720.jpg',
    bio: "I love helping others experience the rich culture of the Indian mountains. I'm an American living in India, married to an Indian, slowly metamorphosing into a half-desi half-foreigner. I love extended journeys through the small villages of the Himalaya — looking for new trails and hidden villages to share with others.",
  },
  {
    name: 'Lenduk Lhomi',
    region: 'Nepal',
    image: '/images/2023/06/Lenduk-Lhomi-1024x720.jpg',
    bio: "Tashi Delek! I am Lenduk. Born and raised in Nepal, the mountains are my home. I've successfully summited Everest, Ama Dablam, Island Peak, Mera Peak, and Lobuche. But more than peak-bagging, I love time with people. I'm here to share my home with you.",
  },
  {
    name: 'Stanzin Padma',
    region: 'India',
    image: '/images/2025/06/stanzin-bio-1024x720.jpg',
    bio: "Julley travelers! I'm Stanzin, a local guide from Ladakh. I was born here and grew up surrounded by mountains, local culture, and a deep connection to nature. As a female guide, I want to show others that women in Ladakh can lead, inspire, and make a difference.",
  },
];
---
<Base title="About Adventure Access — A community of guides across the Himalayas" description="With diverse backgrounds from the United States, China, India, Nepal and Bhutan, Adventure Access is a community of guides, operators, and hospitality experts across the Himalayas.">

  <!-- HERO BANNER ON PHOTO -->
  <section class="relative h-[60vh] md:h-[75vh] overflow-hidden bg-ink">
    <img
      src="/images/2023/06/About-Us-General-2-scaled.jpg"
      alt="Adventure Access guides at work in the Himalayas"
      class="absolute inset-0 w-full h-full object-cover kenburns"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-ink/40 via-ink/15 to-ink/85"></div>
    <div class="relative z-10 h-full max-w-8xl mx-auto px-6 md:px-14 flex flex-col justify-end pb-16 md:pb-24 text-cream">
      <div class="max-w-3xl">
        <div class="eyebrow-cream mb-6 fade-up text-shadow-hero">— About Adventure Access</div>
        <h1 class="display text-6xl md:text-8xl fade-up-delay-1 text-shadow-hero">
          We believe real adventure<br>changes <em class="not-italic font-light text-saffron font-display italic">you</em>.
        </h1>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="bg-cream py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6 md:px-14">
      <div class="font-display text-xl md:text-3xl italic text-ink-soft leading-relaxed space-y-6">
        <p class="reveal">We've been trekking, biking, and climbing in Tibet, Nepal, Bhutan, and India for over twenty years — and we want to share our adventure opportunities in this region with you. Bring your friends along, or make new ones along the way.</p>
      </div>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section class="bg-paper py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6 md:px-14 text-lg leading-relaxed text-ink-soft space-y-6">
      <p class="reveal">Simply stated, we are here to put you on the mountain. The Tibetan Plateau and the broader Himalayan region is an amazing place to experience — but with little infrastructure it can be a maddening region if you don't have connections and resources. That's where we come in.</p>
      <p class="reveal" data-delay="100">We've been living and working throughout the region for over 20 years. We bring you experiences born out of the past, and the true success is our deep relationships with the locals from this region.</p>
      <p class="reveal" data-delay="200">Trekking, mountain biking, mountaineering, cultural experiences, and tours in the national parks are some of the avenues we use to explore this great region. Come join us.</p>
    </div>
  </section>

  <!-- COMMUNITY — dark section -->
  <section class="bg-ink text-cream py-28 md:py-36">
    <div class="max-w-8xl mx-auto px-6 md:px-14">
      <div class="max-w-3xl mb-16 reveal">
        <div class="eyebrow-cream mb-4">— Our Community</div>
        <h2 class="display text-5xl md:text-7xl mb-6">A network you can <em class="not-italic font-light text-saffron font-display italic">trust</em>.</h2>
        <p class="text-lg text-cream/80 leading-relaxed">
          With diverse backgrounds from the United States, China, India, Nepal and Bhutan,
          we provide unparalleled experiences that blend the needs of our clients with
          a local understanding of what it takes to experience the best a place has to offer.
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10">
        {team.map((m, i) => (
          <div class="reveal" data-delay={String(Math.min(i * 100, 400))}>
            <div class="aspect-[4/5] overflow-hidden bg-ink-soft mb-5">
              <img src={m.image} alt={m.name} loading="lazy" class="w-full h-full object-cover" />
            </div>
            <div class="eyebrow mb-2">{m.region && `— ${m.region}`}</div>
            <h3 class="font-display text-2xl mb-3 text-cream">{m.name}</h3>
            {m.bio && <p class="text-sm text-cream/75 leading-relaxed">{m.bio}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GOAL -->
  <section id="our-goal" class="py-24 md:py-32 bg-cream">
    <div class="max-w-8xl mx-auto px-6 md:px-14 grid lg:grid-cols-2 gap-16 lg:gap-24">
      <div class="reveal-left">
        <div class="eyebrow mb-4">— Our Goal</div>
        <h2 class="display text-5xl md:text-6xl mb-8">Adventure with <em class="not-italic font-light text-saffron font-display italic">care</em>.</h2>
        <p class="text-lg text-ink-soft leading-relaxed">
          We strive to provide adventurers with the best of outdoor experiences while also fostering
          quality cultural interaction. We're committed to developing better life and work opportunities
          for local nomads and villagers, educating clients and communities about the needs of their
          surroundings, and leaving a better environment for the future.
        </p>
      </div>
      <div class="space-y-10 reveal-right">
        <div class="border-t-2 border-saffron pt-6">
          <h3 class="font-display text-2xl mb-3">Social Enterprise</h3>
          <p class="text-ink-soft leading-relaxed">
            We invest in local entrepreneurs and their employees to build a strong network of adventure
            providers and hospitality points throughout the region. When you choose Adventure Access
            you become an investor in the local adventure ecosystem.
          </p>
        </div>
        <div class="border-t-2 border-saffron pt-6">
          <h3 class="font-display text-2xl mb-3">Our Commitment</h3>
          <p class="text-ink-soft leading-relaxed">
            We want you to have a great experience — but not at the expense of the local community
            and environment. We are committed to responsible tourism that develops communities,
            enriches lives, and improves the environment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA on photo -->
  <section class="relative overflow-hidden">
    <img
      src="/images/2024/05/Ladakh-hero-image.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-ink/85 via-ink/65 to-ink/40"></div>
    <div class="relative z-10 max-w-8xl mx-auto px-6 md:px-14 py-24 md:py-32 text-cream">
      <div class="max-w-2xl reveal">
        <div class="eyebrow-cream mb-6">— Plan a trip</div>
        <h2 class="display text-5xl md:text-6xl mb-8 text-shadow-hero">Come adventure with us.</h2>
        <a href="mailto:info@adventure-access.com" class="btn-cream">Start the conversation</a>
      </div>
    </div>
  </section>

</Base>
