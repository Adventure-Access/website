---
import DestinationCard from './DestinationCard.astro';

export interface Destination {
  slug: string;
  country: string;
  name: string;
  tagline?: string;
  blurb: string;
  hero: string;
}
export interface Props {
  destinations: Destination[];
}
const { destinations } = Astro.props;
---
<div class="destinations-scroller" data-count={destinations.length}>
  <div class="h-scroller" role="region" aria-label="Adventure Access destinations">
    {destinations.map((d, i) => (
      <DestinationCard
        slug={d.slug}
        country={d.country}
        name={d.name}
        tagline={d.tagline}
        blurb={d.blurb}
        hero={d.hero}
        index={i}
      />
    ))}
  </div>

  <div class="max-w-8xl mx-auto px-6 md:px-14 mt-4 flex items-center gap-6">
    {/* Progress bar reflects scroll position */}
    <div class="h-scroller-progress flex-1">
      <div class="h-scroller-progress__bar"></div>
    </div>
    {/* Prev / next */}
    <div class="hidden md:flex items-center gap-2">
      <button
        type="button"
        class="w-10 h-10 inline-flex items-center justify-center border border-ink/20 text-ink hover:bg-ink hover:text-cream transition-colors disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:text-ink disabled:cursor-not-allowed"
        data-direction="prev"
        aria-label="Previous destinations"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>
      <button
        type="button"
        class="w-10 h-10 inline-flex items-center justify-center border border-ink/20 text-ink hover:bg-ink hover:text-cream transition-colors disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:text-ink disabled:cursor-not-allowed"
        data-direction="next"
        aria-label="Next destinations"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M9 6l6 6-6 6"/>
        </svg>
      </button>
    </div>
    <div class="text-xs uppercase tracking-[0.18em] text-ink-soft">
      <span class="scroller-current">1</span> / <span>{destinations.length}</span>
    </div>
  </div>
</div>


<script is:inline>
  (function () {
    const roots = document.querySelectorAll('.destinations-scroller');
    roots.forEach((root) => {
      const scroller = root.querySelector('.h-scroller');
      const bar      = root.querySelector('.h-scroller-progress__bar');
      const current  = root.querySelector('.scroller-current');
      const prev     = root.querySelector('[data-direction="prev"]');
      const next     = root.querySelector('[data-direction="next"]');
      if (!scroller) return;

      const cards = Array.from(scroller.children);
      const total = cards.length || 1;

      function update() {
        const max = scroller.scrollWidth - scroller.clientWidth;
        const pct = max > 0 ? scroller.scrollLeft / max : 0;
        if (bar) {
          // Bar represents the visible window width relative to total
          const visibleFrac = Math.min(1, scroller.clientWidth / scroller.scrollWidth);
          bar.style.width = (visibleFrac * 100).toFixed(2) + '%';
          bar.style.transform = `translateX(${(pct * (1 - visibleFrac) * 100 / visibleFrac).toFixed(2)}%)`;
        }
        // Closest card index (1-based)
        if (current) {
          let active = 0;
          let bestDist = Infinity;
          cards.forEach((card, i) => {
            const cardLeft = card.offsetLeft;
            const dist = Math.abs(cardLeft - scroller.scrollLeft);
            if (dist < bestDist) { bestDist = dist; active = i; }
          });
          current.textContent = String(active + 1);
        }
        if (prev) prev.disabled = scroller.scrollLeft <= 4;
        if (next) next.disabled = scroller.scrollLeft >= (scroller.scrollWidth - scroller.clientWidth - 4);
      }

      function step(direction) {
        const first = cards[0];
        const stepSize = first ? first.offsetWidth + parseInt(getComputedStyle(scroller).gap || '0', 10) : scroller.clientWidth * 0.8;
        scroller.scrollBy({ left: direction * stepSize, behavior: 'smooth' });
      }

      scroller.addEventListener('scroll', () => requestAnimationFrame(update), { passive: true });
      window.addEventListener('resize', update);
      if (prev) prev.addEventListener('click', () => step(-1));
      if (next) next.addEventListener('click', () => step(1));

      // Initial paint
      requestAnimationFrame(update);
    });
  })();
</script>
